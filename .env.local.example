# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email Notifications (SMTP - e.g. Gmail, SendGrid, Mailgun)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
NOTIFICATION_EMAIL=Admin@WalkWaytoHealing.com
FROM_EMAIL=noreply@walkwaytohealing.com

# Site
NEXT_PUBLIC_SITE_URL=https://walkwaytohealing.com

# Rate limiting (seconds between submissions per IP)
RATE_LIMIT_WINDOW=300
RATE_LIMIT_MAX=3
